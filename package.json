{
  "name": "bun-better-sqlite3",
  "version": "1.0.0",
  "description": "Drop-in better-sqlite3 API compatibility layer for Bun — maps the better-sqlite3 API to bun:sqlite",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/cjs-entry.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "bun",
    "bun:sqlite",
    "better-sqlite3",
    "sqlite",
    "polyfill",
    "compatibility",
    "drop-in",
    "drizzle",
    "knex",
    "strapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moghancy/bun-better-sqlite3.git"
  },
  "homepage": "https://github.com/moghancy/bun-better-sqlite3#readme",
  "bugs": {
    "url": "https://github.com/moghancy/bun-better-sqlite3/issues"
  },
  "author": "Amir Moghaddam (Moghancy)",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  }
}
